# ===== DATABASE =====
DATABASE_URL=postgres://postgres:YOUR_PASSWORD@localhost:5432/trueqi

# ===== REDIS =====
# Use Upstash URL: rediss://default:TOKEN@HOST:PORT
REDIS_URL=redis://localhost:6379

# ===== SECRETS =====
JWT_SECRET=change-me-to-a-long-random-string-in-production
COOKIE_SECRET=change-me-to-another-long-random-string

# ===== CORS =====
# Admin panel (apps/admin-test) runs on port 7000
# Vendor panel (apps/vendor) runs on port 7001
# Storefront would run on port 8000
STORE_CORS=http://localhost:8000
ADMIN_CORS=http://localhost:7000
VENDOR_CORS=http://localhost:7001
AUTH_CORS=http://localhost:7000,http://localhost:7001,http://localhost:8000

# ===== MEDUSA =====
NODE_ENV=development
